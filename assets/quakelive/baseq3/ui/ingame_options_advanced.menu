		//LEFT BOX
		itemDef {
			name advGame
			group grpControls
			style WINDOW_STYLE_FILLED	
			rect 105 46 190 205
			border 1
			bordercolor .6 .6 .6 0.5
			backcolor 0.22 0.22 0.22 0.5
			decoration
			visible 0
		}

		itemDef {
			name advGame
			group grpControls
			text "Screen shake on hit:"
			rect 115 50 180 15
			textalign ITEM_ALIGN_LEFT
			textaligny 12
			textscale .18          
			forecolor 1 1 1 1
			visible 0 
			style WINDOW_STYLE_FILLED 
			decoration
		}

		itemDef {
			name advGame
			group grpControls
			type ITEM_TYPE_MULTI
			text ""
			cvar "cg_kickScale"
			cvarFloatList { "No" 0 "Low" 0.25 "Medium" 0.5 "High" 1 }
			rect 215 50 90 15
			textalign ITEM_ALIGN_LEFT
			textaligny 12
			textscale .18          
			forecolor 1 1 1 1
			visible 0 
			mouseenter { show cg_kickscale_tooltip }
			mouseexit { hide cg_kickscale_tooltip }
		}

		itemDef {
			name cg_kickscale_tooltip
			group grpControlsTooltip
			rect 105 265 300 15
			text "Control the amount your screen shakes when you receive damage."      
			forecolor 0.964 0.815 0 1
			textscale .20
			textalign ITEM_ALIGN_LEFT
			visible 0
			decoration 
		}

