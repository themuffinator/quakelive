//****ADVANCED****//

		itemDef {
			name advGameText
			group grpControlsAdvMenu
			text " GAME OPTIONS"
			textscale .16
			style WINDOW_STYLE_FILLED	
			rect 20 50 83 15 
			backcolor .3 .3 .3 1
			forecolor 0.964 0.815 0 1
			textalign ITEM_ALIGN_LEFT     
			textaligny 11
			decoration
			visible 1 	  
		}

		itemDef {
			name advGameButton
			type 1
			group grpControlsAdvMenu
			style WINDOW_STYLE_FILLED
			rect 20 48 83 17
			backcolor 0 0 0 0
			visible 1
			action { hide grpControls ; show advGame 
				setitemcolor advGameText backcolor .3 .3 .3 1
				setitemcolor advGameText forecolor 0.964 0.815 0 1
				setitemcolor advHudText backcolor 0.133 0.133 0.133 1.0
				setitemcolor advHudText forecolor 0.525 0.525 0.525 1
				setitemcolor advWeapText backcolor 0.133 0.133 0.133 1.0
				setitemcolor advWeapText forecolor 0.525 0.525 0.525 1
				setitemcolor advWeapConfigText backcolor 0.133 0.133 0.133 1.0
				setitemcolor advWeapConfigText forecolor 0.525 0.525 0.525 1
				setitemcolor advTeamText backcolor 0.133 0.133 0.133 1.0
				setitemcolor advTeamText forecolor 0.525 0.525 0.525 1
				setitemcolor advVideoText backcolor 0.133 0.133 0.133 1.0
				setitemcolor advVideoText forecolor 0.525 0.525 0.525 1
				setitemcolor advShaderText backcolor 0.133 0.133 0.133 1.0
				setitemcolor advShaderText forecolor 0.525 0.525 0.525 1
				setitemcolor advSoundText backcolor 0.133 0.133 0.133 1.0
				setitemcolor advSoundText forecolor 0.525 0.525 0.525 1
				setitemcolor advSpectatingText backcolor 0.133 0.133 0.133 1.0
				setitemcolor advSpectatingText forecolor 0.525 0.525 0.525 1
			}
			onFocus {
				transition advGameText 21 50 83 15 20 50 83 15 20 10
			}
		}

