		itemDef {
			name players
			group grpAdmin
			rect 26 40 150 229
			style WINDOW_STYLE_FILLED
			type ITEM_TYPE_LISTBOX
			elementwidth 100
			elementheight 16
			font FONT_SANS
			textscale .18
			elementtype LISTBOX_TEXT
			feeder FEEDER_PLAYER_LIST
			border 1
			bordercolor 0.15 0.15 0.15 1.0
			forecolor 1 1 1 1
			backcolor 0 0 0 .25
			outlinecolor 0.70 0.70 0.70 0.8
			visible 1
			mouseEnter { setitemcolor kick bordercolor .7 0 0 1 } 
			mouseExit { setitemcolor kick bordercolor .5 .5 .5 1 }
		}

		//		Client Commands
