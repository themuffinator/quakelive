#include "ui/menudef.h"

{
\\ SERVER ADMIN MENU \\

	menuDef {
		name "ingame_admin"
		visible 0
		fullscreen 0
		rect 39 99 560 480
		focusColor 0.964 0.815 0 1
		style WINDOW_STYLE_FILLED
		border 1
		disableColor .5 .5 .5 1	

		itemDef {
			name status
			text "Match Administration"
			textscale .28
			textalign ITEM_ALIGN_LEFT
			style WINDOW_STYLE_EMPTY	
			rect 20 0 100 30 
			forecolor 0.525 0.525 0.525 1
			decoration
			visible 1
		}
		
		onOpen { hide grpAdminTooltip }
		
		itemDef {
			name admin_bar
			rect 20 3 520 1
			style WINDOW_STYLE_FILLED 
			visible 1 
			decoration 
			backcolor 0.525 0.525 0.525 1
		}
