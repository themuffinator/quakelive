//health value/icon
	menuDef {
		name "Player"
		widescreen WIDESCREEN_CENTER
		fullScreen MENU_FALSE
		visible MENU_TRUE
		rect 197 449 95 36

		itemDef {
			name "playerRect"
			rect 21 -5 52 36
			style WINDOW_STYLE_SHADER
			background "ui/assets/hud/healthalert"
			visible 1
			ownerdrawflag CG_SHOW_HEALTHCRITICAL            
		}

		itemDef {
			name "HealthIconShadow"
			backcolor 0 0 0 0.8
			rect 2 7 18 18
			visible 1
			decoration
			style WINDOW_STYLE_FILLED
			background "ui/assets/hud/health.tga"
		}
		
		itemDef {
			name "HealthIcon"
			rect 1 6 18 18
			ownerdraw CG_TEAM_COLORIZED
			visible 1
			decoration
			style WINDOW_STYLE_FILLED
			background "ui/assets/hud/health.tga"
		}
		
		itemDef {
			name "HealthValue"
			rect 45 0 63 22
			visible 1
			align ITEM_ALIGN_CENTER
			decoration
			textstyle ITEM_TEXTSTYLE_SHADOWED
			forecolor 1 1 1 1
			textscale .5
			font FONT_DEFAULT
			ownerdraw CG_PLAYER_HEALTH
			addColorRange -999 25 1 0 0 1
		}
	}

//*****AMMO*****//

	menuDef {
			name "Ammo"
			widescreen WIDESCREEN_CENTER
			fullScreen MENU_FALSE
			visible MENU_TRUE
			rect 283 449 99 36
		
		itemDef {
			name "AmmoIcon"
			rect 0 6 18 18
			visible 1
			decoration
			ownerdraw CG_PLAYER_AMMO_ICON2D
		}

		itemDef {
			name "AmmoValue"
			rect 45 0 24 32
			visible 1
			textstyle ITEM_TEXTSTYLE_SHADOWED
			align ITEM_ALIGN_CENTER
			decoration
			textscale .5
			font FONT_DEFAULT
			forecolor 1 1 1 1
			ownerdraw CG_PLAYER_AMMO_VALUE
			addColorRange -999 -1 1 1 1 1
			addColorRange 0 5 1 0 0 1
		}
	}

//armor value/icon
	menuDef {
			name "Armor"
			widescreen WIDESCREEN_CENTER
			fullScreen MENU_FALSE
			visible MENU_TRUE	
			rect 369 449 95 32

		itemDef {
			name "ArmorIconShadow"
			backcolor 0 0 0 0.8
			rect 2 7 18 18 
			visible 1
			decoration
			style WINDOW_STYLE_FILLED
			background "ui/assets/hud/armor.tga"
		}
		
		itemDef {
			name "ArmorIcon"
			backcolor 0.0 0.0 0.0 0.8
			ownerdraw CG_TEAM_COLORIZED
			rect 1 6 18 18 
			visible 1
			decoration
			style WINDOW_STYLE_FILLED
			background "ui/assets/hud/armor.tga"
			cvarTest "cg_armorTiered"
			hideCvar { "1" }  
		}
		
		itemDef {
			name "ArmorIcon"
			ownerdraw CG_ARMORTIERED_COLORIZED
			rect 1 5 18 18 
			visible 1
			decoration
			style WINDOW_STYLE_FILLED
			background "ui/assets/hud/armor.tga"
			cvarTest "cg_armorTiered"
			showCvar { "1" }  
		}

		itemDef {
			name "ArmorValue"
			rect 45 0 63 22
			visible 1
			decoration
			textstyle ITEM_TEXTSTYLE_SHADOWED	
			textscale .5
			font FONT_DEFAULT
			align ITEM_ALIGN_CENTER
			ownerdraw CG_PLAYER_ARMOR_VALUE 
			addColorRange -999 25 .67 0 0 1
		}
	}

