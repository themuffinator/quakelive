// advert showing at the end of the game 4x1, 256x64, ~5% of screen
itemDef {
	name advert2
	ownerdraw UI_ADVERT
	ownerdrawFlag CG_SHOW_INTERMISSION
	type ITEM_TYPE_BUTTON
   	rect 453 26 160 80
    defaultContent "textures/ad_content/ad2x1.jpg"
   	cellId 2
 	style WINDOW_STYLE_SHADER
	forecolor 1 1 1 1.0
   	visible 1 
   	action { activateAdvert 2 }
