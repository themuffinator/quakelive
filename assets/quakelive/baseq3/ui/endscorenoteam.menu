//WINNER BAR TEXT

	//MODEL WINDOW
	itemDef {
		name model
		// this rect should have a 4:3 aspect ratio for the model to scale properly
		rect -28 20 200 165 //-68 0 300 225 rect for 4:3
		backcolor 0 0 0 0
		visible 1
		ownerdraw CG_1STPLACE_PLYR_MODEL
		decoration	  
	}
	//GAME INFO
	itemDef {
		name gametype
		ownerdraw CG_GAME_TYPE
		text ""
		textalign ITEM_ALIGN_CENTER
		textscale .18
		rect 178 36 90 10		 
		forecolor 0.8 0.8 0.8 1
		decoration
		visible 1 	  
	}


	itemDef {
		name timelimit
		type 4
		text "Timelimit:"
