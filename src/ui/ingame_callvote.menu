			textalign ITEM_ALIGN_LEFT
			decoration
			visible 1
			text "Map Options"
			textscale .18
			textalignx 4
			textaligny 10
		}
		
		itemDef {
      		name "restart"
			group grpCallVote
			rect 271 41 220 15
			textaligny 11
      		textalign ITEM_ALIGN_LEFT
			font FONT_SANS
			textscale .2               
      		forecolor 1 1 1 1
      		visible 1
      		style WINDOW_STYLE_FILLED
      		border 0
			bordercolor .5 .5 .5 .5
			text "Restart Map"
			action { exec "cmd callvote map_restart" ; uiScript closeingame }
    	}
		
		itemDef {
      		name "nxtMap"
			group grpCallVote
			rect 271 61 220 15
			textaligny 11
      		textalign ITEM_ALIGN_LEFT
			font FONT_SANS
			textscale .2               
      		forecolor 1 1 1 1
      		visible 1
      		style WINDOW_STYLE_FILLED
      		border 0
			bordercolor .5 .5 .5 .5
			text "Next Map"
			action { exec "cmd callvote nextmap" ; uiScript closeingame }
			cvarTest "ui_mapVotingDisabled"
			hideCvar { "1" }
    	}

		//RIGHT BOX 2
		itemDef {
			name basic
			group grpControls
			style WINDOW_STYLE_FILLED	
			rect 265 94 230 143 
			border 1
			bordercolor .6 .6 .6 0.5
			backcolor 0.22 0.22 0.22 0.5
			textalign ITEM_ALIGN_LEFT
			decoration
			visible 1
			cvarTest "ui_mapVotingDisabled"
			hideCvar { "1" }
		}
		
		itemDef {
      		name "gamemode"
			group grpCallVote
			rect 272 96 220 15
			textaligny 11
      		textalign ITEM_ALIGN_LEFT
			textscale .2            
      		forecolor .5 .5 .5 1
      		visible 1
