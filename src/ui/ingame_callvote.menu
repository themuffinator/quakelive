      		visible 1
      		style WINDOW_STYLE_FILLED
      		border 0
			bordercolor .5 .5 .5 .5
			text "Shuffle Teams:"
			cvarTest "cg_gametype"
			hideCvar { "0" ; "1" ; "2" ; "12" }
