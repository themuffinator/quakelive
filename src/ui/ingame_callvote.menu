      		border 0
			bordercolor .5 .5 .5 .5
			text "ON"
			action { exec "cmd callvote loadouts on" ; uiScript closeingame }
    	}
		
		itemDef {
      		name "loadouts"
			group grpCallVote
			rect 190 61 25 15
			textaligny 11
      		textalign ITEM_ALIGN_LEFT
			font FONT_SANS
			textscale .2               
      		forecolor 1 1 1 1
      		visible 1
      		style WINDOW_STYLE_FILLED
      		border 0
			bordercolor .5 .5 .5 .5
			text "OFF"
			action { exec "cmd callvote loadouts off" ; uiScript closeingame }
    	}
		
		itemDef {
      		name "ammo"
			group grpCallVote
			rect 30 81 220 15
			textaligny 11
      		textalign ITEM_ALIGN_LEFT
			textscale .2               
      		forecolor .5 .5 .5 1
      		visible 1
      		style WINDOW_STYLE_FILLED
			text "Ammo:"
			decoration
			cvarTest "cg_gametype"
			hideCvar { "2" ; "4" ; "10" ; "12" }
    	}	
		
		itemDef {
      		name "ammo"
			group grpCallVote
			rect 120 81 25 15
			textaligny 11
      		textalign ITEM_ALIGN_LEFT
