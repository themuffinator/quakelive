      		visible 1
      		style WINDOW_STYLE_FILLED
      		border 0
			bordercolor .5 .5 .5 .5
			text "GLOBAL"
			cvarTest "cg_gametype"
			hideCvar { "2" ; "4" ; "10" ; "12" }
			action { exec "cmd callvote ammo global" ; uiScript closeingame }
    	}
		
		itemDef {
      		name "ammo"
