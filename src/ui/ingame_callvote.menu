#include "ui/menudef.h"

{
\\ CALL VOTE MENU \\

menuDef {
	name "ingame_callvote"
	visible 0
	fullscreen 0
	rect 39 99 560 480
	focusColor 0.70 0.70 0.70 0.8
	style WINDOW_STYLE_FILLED
	border 1
	disableColor .5 .5 .5 1
	onopen { uiScript loadArenas }

		itemDef {
			name status
			text "Call Vote"
			textscale .28
			textalign ITEM_ALIGN_LEFT
			style WINDOW_STYLE_EMPTY	
			rect 20 0 100 30 
			forecolor 0.525 0.525 0.525 1
			decoration
			visible 1
		}
		
		itemDef {
			name callvote_bar
			rect 20 3 520 1
			style WINDOW_STYLE_FILLED 
			visible 1 
			decoration 
			backcolor 0.525 0.525 0.525 1
		}

		//LEFT BOX 1	
		itemDef {
			name basic
			group grpCallVote
			style WINDOW_STYLE_FILLED	
			rect 24 20 230 217 
			border 1
			bordercolor .6 .6 .6 0.5
			backcolor 0.22 0.22 0.22 0.5
			textalign ITEM_ALIGN_CENTER
			decoration
			visible 1
		}
		
		itemDef {
			name "gameOpt"
			group grpCallVote
			style WINDOW_STYLE_FILLED	
			rect 26 22 228 14
			backcolor 0.12 0.12 0.12 1
			textalign ITEM_ALIGN_LEFT
			decoration
			visible 1
			text "Game Options"
			textscale .18
			textalignx 4
			textaligny 10
		}
		
		itemDef {
      		name "cointoss"
			group grpCallVote
			rect 30 41 220 15
			textaligny 11
      		textalign ITEM_ALIGN_LEFT
			textscale .2            
      		forecolor .5 .5 .5 1
      		visible 1
      		style WINDOW_STYLE_FILLED
      		border 0
			bordercolor .5 .5 .5 .5
			text "Random"
			decoration
    	}		
		
		itemDef {
      		name "cointoss"
			group grpCallVote
			rect 120 41 25 15
			textaligny 11
      		textalign ITEM_ALIGN_LEFT
			font FONT_SANS
			textscale .2               
      		forecolor 1 1 1 1
      		visible 1
      		style WINDOW_STYLE_FILLED
      		border 0
			bordercolor .5 .5 .5 .5
			text "Cointoss"
			action { exec "cmd callvote cointoss" ; uiScript closeingame }
    	}		
		
		itemDef {
      		name "cointoss"
			group grpCallVote
			rect 190 41 25 15
			textaligny 11
      		textalign ITEM_ALIGN_LEFT
			font FONT_SANS
			textscale .2               
      		forecolor 1 1 1 1
      		visible 1
      		style WINDOW_STYLE_FILLED
      		border 0
			bordercolor .5 .5 .5 .5
			text "d20"
			action { exec "cmd callvote random 20" ; uiScript closeingame }
    	}		
		
		itemDef {
      		name "loadouts"
			group grpCallVote
			rect 30 61 220 15
			textaligny 11
      		textalign ITEM_ALIGN_LEFT
			textscale .2               
      		forecolor .5 .5 .5 1
      		visible 1
      		style WINDOW_STYLE_FILLED
			text "Loadouts:"
			decoration
    	}	
		
		itemDef {
      		name "loadouts"
			group grpCallVote
			rect 120 61 25 15
			textaligny 11
      		textalign ITEM_ALIGN_LEFT
			font FONT_SANS
			textscale .2               
      		forecolor 1 1 1 1
      		visible 1
