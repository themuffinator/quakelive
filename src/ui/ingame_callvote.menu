		itemDef {
			name basic
			text "   Call Vote"
			type 1
			textscale .2
			group grpCallVote
			style WINDOW_STYLE_FILLED
			rect 422 207 58 15
			textalign ITEM_ALIGN_CENTER
			textalignx 25
			textaligny 11
			forecolor 1 1 1 1
			backcolor 0.375 0.125 0.125 1.0
			visible 1
