		itemDef {
      		name "cvmap"
			group grpCallVote
			rect 267 96 228 14
			textscale .18
			textalignx 4
			textaligny 10
      		textalign ITEM_ALIGN_LEFT     
			backcolor 0.12 0.12 0.12 1
      		visible 1
      		style WINDOW_STYLE_FILLED
			text "Callvote Map"
			decoration
			cvarTest "ui_mapVotingDisabled"
			showCvar { "0" }
			cvarTest2 "ui_gameTypeVotingDisabled"
			showCvar2 { "1" }
    	}		
		
		itemDef {
			name advGame
			group grpCallVote
			type ITEM_TYPE_MULTI
			text ""
			cvar "ui_cvgametype"
			cvarFloatList { "Default" -1 "FFA" 0 "Duel" 1 "Race" 2 "TDM" 3 "CA" 4 "CTF" 5 "1F" 6 "HAR" 8 "FT" 9 "DOM" 10 "AD" 11 "RR" 12 }
			rect 382 96 139 20
			textaligny 11
			textalign ITEM_ALIGN_LEFT
			font FONT_SANS
			textscale .18          
			forecolor 1 1 1 1
			visible 1
			cvarTest "ui_mapVotingDisabled"
			hideCvar { "1" }
			cvarTest2 "ui_gameTypeVotingDisabled"
			hideCvar2 { "1" }
			action { uiScript updateCallvoteMapPreview }
		}
		
		itemDef {
			name map
			group grpCallVote
			rect 267 114 139 120
			style WINDOW_STYLE_FILLED
			type ITEM_TYPE_LISTBOX
			elementwidth 120
			elementheight 18
			font FONT_SANS
			textscale .18
			elementtype LISTBOX_TEXT
			feeder FEEDER_CVMAPS
			border 1
			bordercolor .5 .5 .5 .5
			forecolor 1 1 1 1
			backcolor 0 0 0 .25
			outlinecolor 0.70 0.70 0.70 0.8
			visible 1
			mouseEnter { setitemcolor map bordercolor .7 0 0 1 } 
			mouseExit { setitemcolor map bordercolor .5 .5 .5 1 }
			cvarTest "ui_mapVotingDisabled"
			hideCvar { "1" }
			cvarTest2 "ui_gameTypeVotingDisabled"
			hideCvar2 { "1" }
		}
		
		itemDef {
			name map
			group grpCallVote
			rect 267 114 139 120
			style WINDOW_STYLE_FILLED
			type ITEM_TYPE_LISTBOX
			elementwidth 120
			elementheight 18
			font FONT_SANS
			textscale .18
			elementtype LISTBOX_TEXT
			feeder FEEDER_ALLMAPS
			border 1
			bordercolor .5 .5 .5 .5
			forecolor 1 1 1 1
			backcolor 0 0 0 .25
			outlinecolor 0.70 0.70 0.70 0.8
			visible 1
			mouseEnter { setitemcolor map bordercolor .7 0 0 1 } 
			mouseExit { setitemcolor map bordercolor .5 .5 .5 1 }
			cvarTest "ui_mapVotingDisabled"
			showCvar { "0" }
