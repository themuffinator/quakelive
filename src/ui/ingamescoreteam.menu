	textscale .18
	elementtype LISTBOX_TEXT
	feeder FEEDER_REDTEAM_LIST
	notselectable
	columns 8  1 15 1  1 15 16  17 15 1  32 100 16  155 16 5  194 16 5  220 16 3  247 16 4
	}

