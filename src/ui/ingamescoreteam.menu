 	style WINDOW_STYLE_SHADER
	forecolor 1 1 1 1.0
   	visible 1 
	decoration
	}
	
//TEXT


	//map detail
	itemDef {
		name mapname
		ownerdraw CG_MAP_NAME
		textscale .2
		style WINDOW_STYLE_EMPTY	
		rect 25 88 418 10 
		textalign ITEM_ALIGN_LEFT		
		backcolor 0 0 0 0
		forecolor 0.8 0.8 0.8 1
		visible 1 
		decoration	  
	}
	//killer
	itemDef {
		name winner
		ownerdraw CG_KILLER
