	}
	//clan arena count
	itemDef {
		name "clanArena"
		rect 33 2 21 11
		visible 1
		backcolor 1 1 1 1
		decoration	
		style WINDOW_STYLE_FILLED
		ownerdrawflag CG_SHOW_PLAYERS_REMAINING
		background "ui/assets/score/ca_score_red.tga"
