#include "ui/menudef.h"

// spec hud
// defines from ui_shared.h

{
	assetGlobalDef {
		cursor "ui/assets/3_cursor3"					// cursor	
        gradientBar "ui/assets/gradientbar2.tga"	// gradient bar
        fadeClamp 1.0										// sets the fadeup alpha
        fadeCycle 1											// how often fade happens in milliseconds
        fadeAmount 0.1										// amount to adjust alpha per cycle
        shadowX  5											// x amount for shadow offset
        shadowY  5											// y amount for shadow offset
        shadowColor 0.1 0.1 0.1 0.25					// shadow color
        font "fonts/font" 24									// font
        smallFont "fonts/smallfont" 16					// font
        bigFont "fonts/bigfont" 48						// font
	}

//spec hud data

menuDef {
	name "spechud_menu"
    widescreen WIDESCREEN_LEFT
	fullScreen 0
	visible 0
	rect 0 0 64 36

    itemDef {
	    name hudObit
	    ownerdraw CG_PLAYER_OBIT
   	    rect 190 18 65 12
   	    visible 1
	    decoration
	    textscale .22
  	    cvarTest "cg_gametype"
  	    hideCvar { "12" }
	}

    itemDef {
	    name hudObit
	    ownerdraw CG_PLAYER_OBIT
   	    rect 220 18 65 12
   	    visible 1
	    decoration
	    textscale .22
  	    cvarTest "cg_gametype"
  	    showCvar { "12" }
	}
		
	itemDef {
		name "specMode"
        widescreen WIDESCREEN_RIGHT
		ownerdraw CG_SPEC_MESSAGES
		rect 370 18 50 12
		visible 1
		decoration
  	    cvarTest "cg_gametype"
  	    hideCvar { "2" }
	}
		
	itemDef {
		name "specMode"
        widescreen WIDESCREEN_RIGHT
		ownerdraw CG_SPEC_MESSAGES
		rect 380 20 50 12
		visible 1
		decoration
  	    cvarTest "cg_gametype"
  	    showCvar { "2" }
	}
	
//AD
	itemDef {
	    name advert1
        widescreen WIDESCREEN_RIGHT
	    ownerdraw UI_ADVERT
		rect  437 425 200 50	
        defaultContent "textures/ad_content/ad4x1.jpg"
   	    cellId 4
 	    style WINDOW_STYLE_SHADER
	    forecolor 1 1 1 1.0
   	    visible 1
	}
	
//	Notification AREA
    itemDef {
	    name tourneyMsg
        widescreen WIDESCREEN_RIGHT
   	    rect 470 4 32 32
    	style WINDOW_STYLE_FILLED
        background "sprites/foe2.png"
   	    visible 1
        ownerdrawflag CG_SHOW_IF_NOTICE_PRESENT
	    decoration
	    backcolor 1 1 1 1.0
	}
	
    itemDef {
	    name gotMsg
        widescreen WIDESCREEN_RIGHT
   	    rect 504 4 32 32
    	style WINDOW_STYLE_FILLED
        background "sprites/balloon4.png"
   	    visible 1
        ownerdrawflag CG_SHOW_IF_MSG_PRESENT
	    decoration
	    backcolor 1 1 1 1.0
	}

//TOP LEFT SCORE BOX
	itemDef {
     	name "scoreboxl"
	    rect 2 0 32 64 
	    visible 1
   	    decoration
	    backcolor 1 1 1 0.8
	    style WINDOW_STYLE_FILLED
	    background "ui/assets/hud/scoreboxl.tga"
	}
	
	itemDef {
     	name "scorebox2"
	    rect 34 0 143 64 
	    visible 1
   	    decoration
	    backcolor 1 1 1 0.8
	    style WINDOW_STYLE_FILLED
	    background "ui/assets/hud/scoreboxm.tga"
	}
	
	itemDef {
     	name "scorebox3"
	    rect 177 0 8 64 
	    visible 1
   	    decoration
	    backcolor 1 1 1 0.8
	    style WINDOW_STYLE_FILLED
	    background "ui/assets/hud/scoreboxr.tga"
	}
	
//GAMETYPE ICON
    itemDef {
	    name "gameType"
	    rect 8 7 19 19
	    style WINDOW_STYLE_EMPTY
	    backcolor 1 1 1 1
	    ownerdraw CG_GAME_TYPE_ICON
	    visible 1
	    decoration
    }	
	
//WIN VALUE
	itemDef {
      	name "WinLimit"
      	textalign ITEM_ALIGN_CENTER
        rect 9 37 40 12
	    visible 1
    	decoration
	    forecolor 0 0 0 1
	    textscale .26
	    ownerdraw CG_CAPFRAGLIMIT 
	}
	
//GAME TIME
	itemDef {
		name "Timer"
		align ITEM_ALIGN_LEFT
		style WINDOW_STYLE_EMPTY
		rect 15 61 50 12
		visible 1
		textstyle ITEM_TEXTSTYLE_SHADOWED
		decoration
		forecolor 1 1 1 1
		textscale .28
		ownerdraw CG_LEVELTIMER
	}
	
	itemDef {
		name "roundTimer"
		align ITEM_ALIGN_LEFT
		style WINDOW_STYLE_EMPTY
		rect 15 72 50 12
		visible 1
		textstyle ITEM_TEXTSTYLE_SHADOWED
		decoration
		forecolor 0.73 0.73 0.73 0.7
		textscale .22
		ownerdraw CG_ROUNDTIMER
	}
	
	itemDef {
		name "overtime"
		align ITEM_ALIGN_LEFT
		style WINDOW_STYLE_EMPTY
		rect 15 72 50 12
		visible 1
		textstyle ITEM_TEXTSTYLE_SHADOWED
		decoration
		forecolor 1 1 1 0.5
		textscale .22
		ownerdraw CG_OVERTIME
	}
	
	itemDef {
		name "timerIcon"
		rect 0 49 14 14
		style WINDOW_STYLE_FILLED
		backcolor 0 0 0 0.7
		background "icons/icon_time.tga"
		visible 1
		decoration
	}
	
	itemDef {
		name "timerIcon"
		rect -1 48 14 14
		style WINDOW_STYLE_FILLED
		backcolor 0.7 0.7 0.7 0.7
		background "icons/icon_time.tga"
		visible 1
		decoration
	}

// scores
    itemDef {
	    name "1stplace"
	    ownerdraw CG_1ST_PLACE_SCORE
   	    rect 40 19 136 40
   	    visible 1
		textscale .22
	    decoration
	}

    itemDef {
	    name "2ndplace"
	    ownerdraw CG_2ND_PLACE_SCORE
   	    rect 40 36 136 40
   	    visible 1
		textscale .22
	    decoration
	}

// DM/TOURNAMENT BAR
//self top highlight
	itemDef {
     	name "SelfTLeft"
	    rect 34 7 16 16 
	    visible 1
   	    decoration
	    ownerdraw CG_TEAM_COLORIZED
