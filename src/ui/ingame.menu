		}
		
		itemDef {
			name navbtn3o
			rect 159 64 59 17
			style WINDOW_STYLE_FILLED 
			visible 1 
			decoration 
		}
		
		itemDef {
			name navbtn3u
			rect 159 80 59 1
			style WINDOW_STYLE_FILLED 
			visible 1 
			decoration
		}
		
		itemDef {
			name navbtn3t
			rect 159 64 80 20
			text "Admin"
			textscale .18
			style WINDOW_STYLE_EMPTY	
			textalignx 29   
			textaligny 13
			textalign ITEM_ALIGN_CENTER		
			forecolor 1 1 1 1
			visible 1 
			decoration
		}
		
		// Add Bot
		itemDef {
			name navbtn4
			rect 225 64 60 16
			style WINDOW_STYLE_FILLED 
			visible 1 
			type 1
                   cvarTest "ui_singlePlayerActive"
			showCvar { "1" }
			action { open ingame_addbot
				setitemcolor navbtn1t forecolor 1 1 1 1
				setitemcolor navbtn2t forecolor 1 1 1 1
				setitemcolor navbtn3t forecolor 1 1 1 1
				setitemcolor navbtn4t forecolor 0.964 0.815 0 1
				setitemcolor navbtn5t forecolor 1 1 1 1
