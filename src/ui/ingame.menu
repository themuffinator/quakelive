				setitemcolor navbtn4o backcolor 0 0 0 0.9
				setitemcolor navbtn5o backcolor 1 1 1 0
				setitemcolor navbtn6o backcolor 1 1 1 0
				setitemcolor navbtn7o backcolor 1 1 1 0
				setitemcolor navbtn1u backcolor 1 1 1 0
				setitemcolor navbtn2u backcolor 1 1 1 0
				setitemcolor navbtn3u backcolor 1 1 1 0
				setitemcolor navbtn4u backcolor 0.964 0.815 0 1
				setitemcolor navbtn5u backcolor 1 1 1 0
				setitemcolor navbtn6u backcolor 1 1 1 0
				setitemcolor navbtn7u backcolor 1 1 1 0
			}
		}
		
		itemDef {
			name navbtn4o
			rect 226 64 59 17
                   cvarTest "ui_singlePlayerActive"
			showCvar { "1" }
			style WINDOW_STYLE_FILLED 
			visible 1 
			decoration 
		}
		
		itemDef {
			name navbtn4u
			rect 226 80 59 1
			style WINDOW_STYLE_FILLED 
			visible 1 
			decoration
		}
		
		itemDef {
			name navbtn4t
			rect 226 64 80 20
			text "Add Bot"
			textscale .18
			style WINDOW_STYLE_EMPTY	
			textalignx 30   
			textaligny 13
			textalign ITEM_ALIGN_CENTER		
			forecolor 1 1 1 1
			visible 1 
			decoration
                   cvarTest "ui_singlePlayerActive"
			hideCvar { "0" }
		}
		
		// main menu
		itemDef {
			name navbtn5
			rect 354 64 64 16
			style WINDOW_STYLE_FILLED 
			visible 1 
			type 1
