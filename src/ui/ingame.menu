		// leave match
		itemDef {
			name navbtn7
			rect 487 64 72 16
			style WINDOW_STYLE_FILLED 
			visible 1 
			type 1
			// joingame_menu menu uses "disconnect", ingame menu users "uiScript leave"
        	action { uiScript leave } 
		}
		
		itemDef {
			name navbtn7t
			rect 488 64 64 20
			text "Leave Match"
			textscale .18
			style WINDOW_STYLE_EMPTY	
