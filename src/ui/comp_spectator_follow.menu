                }

                itemDef {
                        name second_player_name
                        rect 405 28 96 20
                        widescreen WIDESCREEN_CENTER
                        ownerdraw CG_2ND_PLYR
                        textscale 0.3
                        textstyle ITEM_TEXTSTYLE_SHADOWED
                        align ITEM_ALIGN_LEFT
                        visible 1
                }

                itemDef {
                        name follow_name
                        rect 320 60 200 20
                        widescreen WIDESCREEN_CENTER
                        align ITEM_ALIGN_CENTER
                        ownerdraw CG_FOLLOW_PLAYER_NAME_EX
                        textscale 0.25
                        textstyle ITEM_TEXTSTYLE_SHADOWED
                        visible 1
                }
        }
