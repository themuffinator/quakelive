{
  "package": "pak_uiql.pk3",
  "description": "Fonts and HUD/UI dependencies sourced from assets/quakelive/baseq3/fonts and bundled so FS_InitFilesystem can satisfy Quake Live font lookups.",
  "files": [
    {
      "source": "assets/quakelive/baseq3/default.cfg",
      "destination": "default.cfg",
      "description": "Baseline Quake Live bindings expected by FS_InitFilesystem"
    },
    {
      "source": "assets/quakelive/baseq3/fonts/handelgothic.ttf",
      "destination": "fonts/handelgothic.ttf",
      "roles": ["font", "bigFont"],
      "license": "Handel Gothic remains proprietary; limit redistribution to Quake Live compatibility testing."
    },
    {
      "source": "assets/quakelive/baseq3/fonts/notosans-regular.ttf",
      "destination": "fonts/notosans-regular.ttf",
      "roles": ["smallFont"],
      "license": "Apache License 2.0 (Google Noto Sans)."
    },
    {
      "source": "assets/quakelive/baseq3/fonts/droidsansmono.ttf",
      "destination": "fonts/droidsansmono.ttf",
      "roles": ["mono"],
      "license": "Apache License 2.0 (Google Droid Sans Mono)."
    },
    {
      "source": "assets/quakelive/baseq3/fonts/droidsansfallbackfull.ttf",
      "destination": "fonts/droidsansfallbackfull.ttf",
      "roles": ["smallFont", "fallback"],
      "license": "Apache License 2.0 (Google Droid Sans Fallback)."
    },
    {
      "source": "assets/quakelive/baseq3/tim.cfg",
      "destination": "tim.cfg",
      "license": "Quake Live profile snapshot packaged for tutorial flows."
    },
    {
      "source": "assets/quakelive/baseq3/sponge.cfg",
      "destination": "sponge.cfg",
      "license": "Quake Live profile snapshot packaged for tutorial flows."
    },
    {
      "source": "assets/quakelive/baseq3/ttimo.cfg",
      "destination": "ttimo.cfg",
      "license": "Quake Live profile snapshot packaged for tutorial flows."
    },
    {
      "source": "assets/quakelive/baseq3/syncerror.cfg",
      "destination": "syncerror.cfg",
      "license": "Quake Live profile snapshot packaged for tutorial flows."
    },
    {
      "source_dir": "assets/quakelive/baseq3/scripts",
      "destination": "scripts",
      "include": ["ui*.shader"],
      "description": "Shader scripts referenced by Quake Live HUD menus"
    },
    {
      "source_dir": "assets/quakelive/baseq3/ui",
      "destination": "ui",
      "include": ["**/*.menu", "**/*.txt"],
      "description": "Menu scripts and HUD definitions consumed by the native UI module"
    }
  ],
  "audit": {
    "required_paths": [
      "default.cfg",
      "tim.cfg",
      "sponge.cfg",
      "ttimo.cfg",
      "syncerror.cfg",
      "fonts/handelgothic.ttf",
      "fonts/notosans-regular.ttf",
      "fonts/droidsansmono.ttf",
      "fonts/droidsansfallbackfull.ttf",
      "scripts/ui.shader",
      "scripts/ui_hud.shader",
      "ui/main.menu",
      "baseq3/icons",
      "baseq3/levelshots"
    ],
    "required_globs": [
      "ui/**/*.menu",
      "ui/**/*.txt",
      "scripts/ui*.shader",
      "baseq3/icons/**/*",
      "baseq3/levelshots/**/*"
    ]
  }
}
